# Keep URL rewriting off for this folder so the site's pretty-URL rewrite
# rules (inherited from the parent .htaccess) never touch webhook.php.
RewriteEngine Off

# Don't allow the folder contents to be browsed as a directory listing.
Options -Indexes

# --- Protect sensitive files from being downloaded over the web ---
# Blocks the .env secrets file, any dotfile, and stray data files (the SQLite
# database, lock/offset files, logs) from public HTTP access. This is standard
# Apache access control, NOT a firewall rule, so it keeps working even when
# ModSecurity is disabled for this folder. The bot itself reads these files
# from disk (server-side), so blocking web access has zero effect on it.
<FilesMatch "(^\.|\.(sqlite|sqlite3|db|offset|lock|log)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# NOTE on the firewall (ModSecurity):
# Telegram's inbound webhook POSTs are blocked by this host's ModSecurity
# (409). We are currently running in pull mode (poll.php via cron) to bypass
# that. If ModSecurity is later disabled for /bot/, disable it via cPanel
# (Security -> ModSecurity), NOT with a "SecRuleEngine Off" line here - this
# host rejects that directive inside .htaccess and returns a 500 for the folder.
