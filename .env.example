# HabeshaList bot secrets. Copy this file to ".env" (same folder) and fill in
# the real values. The ".env" file is git-ignored so secrets never reach the
# repo. One KEY=value per line. Lines starting with # are ignored.
#
# The bot will refuse to start (HTTP 500) if TELEGRAM_BOT_TOKEN, WEBHOOK_SECRET
# or API_SECRET is missing.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret Telegram echoes in the X-Telegram-Bot-Api-Secret-Token header so the
# webhook can prove a request really came from Telegram. Must match the value
# registered with setWebhook.
WEBHOOK_SECRET=

# Shared secret between the bot and bot-bridge.php on the website
API_SECRET=

# Optional — leave blank unless in use
STRIPE_KEY=
PAYMENT_PROVIDER_TOKEN=

# Master key for the web admin panel's encrypted key storage (AES-256-GCM).
# 32 random bytes, base64-encoded. Generate one with:
#   php -r "echo base64_encode(random_bytes(32));"
# When set, the panel can store the bot token / Stripe key encrypted in the
# database and the bot will use those instead of the plain values above. Keep
# this key ONLY here in .env (never in the database). If it is blank, the panel
# simply falls back to the plain values above - nothing breaks.
HL_APP_KEY=
